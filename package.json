{
  "name": "pauls-custom-cards",
  "version": "0.1.0",
  "description": "Home Assistant custom cards by Paul",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rollup -c rollup.config.js",
    "dev": "rollup -c rollup.config.js --watch",
    "typecheck": "tsc --noEmit",
    "serve": "npx http-server . -p 8080 -c-1 -o /testbed.html"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "rollup": "^4.62.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "custom-card-helpers": "^2.0.0",
    "lit": "^3.3.3"
  }
}
